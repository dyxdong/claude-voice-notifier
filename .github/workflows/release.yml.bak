name: Build and Release

# on:
#  push:
#    tags:
#      - 'v*'

jobs:
  package:
    runs-on: windows-latest
    env:
      S3_BUCKET: ${{ secrets.S3_BUCKET }}
      S3_KEY: ${{ secrets.S3_KEY }}
      AWS_ACCESS_KEY_ID: ${{ secrets.AWS_ACCESS_KEY_ID }}
      RELEASE_ASSET_URL: ${{ secrets.RELEASE_ASSET_URL }}
      RELEASE_ASSET_TOKEN: ${{ secrets.RELEASE_ASSET_TOKEN }}
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup .NET
        uses: actions/setup-dotnet@v3
        with:
          dotnet-version: '8.x'

      - name: Setup Node (optional)
        uses: actions/setup-node@v4
        with:
          node-version: '18'

      - name: Fetch exe from S3 (if configured)
        if: ${{ env.S3_BUCKET != '' && env.S3_KEY != '' && env.AWS_ACCESS_KEY_ID != '' }}
        uses: aws-actions/configure-aws-credentials@v2
        with:
          aws-access-key-id: ${{ secrets.AWS_ACCESS_KEY_ID }}
          aws-secret-access-key: ${{ secrets.AWS_SECRET_ACCESS_KEY }}
          aws-region: ${{ secrets.AWS_REGION }}
      - name: Download exe from S3
        if: ${{ env.S3_BUCKET != '' && env.S3_KEY != '' && env.AWS_ACCESS_KEY_ID != '' }}
        shell: pwsh
        env:
          S3_BUCKET: ${{ secrets.S3_BUCKET }}
          S3_KEY: ${{ secrets.S3_KEY }}
        run: |
          mkdir bin
          aws s3 cp "s3://$env:S3_BUCKET/$env:S3_KEY" ./bin/ClaudeVoiceNotifier.exe

      - name: Fetch exe from GitHub Release asset (if configured)
        if: ${{ env.RELEASE_ASSET_URL != '' }}
        shell: pwsh
        env:
          ASSET_URL: ${{ secrets.RELEASE_ASSET_URL }}
          ASSET_TOKEN: ${{ secrets.RELEASE_ASSET_TOKEN }}
        run: |
          mkdir bin
          if ($env:ASSET_TOKEN) {
            Invoke-WebRequest -Uri $env:ASSET_URL -Headers @{ Authorization = "token $env:ASSET_TOKEN" } -OutFile ./bin/ClaudeVoiceNotifier.exe -UseBasicParsing
          } else {
            Invoke-WebRequest -Uri $env:ASSET_URL -OutFile ./bin/ClaudeVoiceNotifier.exe -UseBasicParsing
          }

      - name: Package release
        shell: pwsh
        run: |
          powershell -ExecutionPolicy Bypass -File .\scripts\package.ps1

      - name: Create Release
        uses: softprops/action-gh-release@v1
        with:
          tag_name: ${{ github.ref_name }}
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}

      - name: Upload Release Assets
        uses: softprops/action-gh-release@v1
        with:
          files: dist\*
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}

